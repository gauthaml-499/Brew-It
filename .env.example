# Copy this file to .env and fill in values as needed.
# This is a static HTML/CSS/JS site, so nothing here is read by the
# browser automatically -- .env is a holding place for whichever key
# you plan to wire up next (see js/config.example.js for the front-end
# side of that wiring).

# Examples of what might go here later:
# GOOGLE_MAPS_API_KEY=
# FORM_ENDPOINT_KEY=      (e.g. Formspree/Netlify Forms/Resend)
# INSTAGRAM_ACCESS_TOKEN=
